---
import Layout from '../../layouts/Layout.astro';
import DemoBanner from '../../components/DemoBanner.astro';

const academy = '피크입시학원';
const accent = '#dc2626';
const year = new Date().getFullYear();

const tracks = [
  { t: '재수종합반', d: '완전 관리형 정규 커리큘럼', tag: 'N수' },
  { t: '반수반', d: '대학 병행 맞춤 시간표', tag: '반수' },
  { t: '의대관', d: '최상위권 의·치·약 전문', tag: '최상위' },
  { t: '내신·정시 병행', d: '고3 재학생 집중관리', tag: '고3' },
];

const manage = [
  { t: '담임 관리', d: '담임이 출결·성적·생활을 1:1 밀착 관리' },
  { t: '주간 모의고사', d: '매주 실전 모의고사 + 성적 분석 리포트' },
  { t: '정시 컨설팅', d: '입시 전문가의 지원 전략 컨설팅 무료 제공' },
  { t: '면학 분위기', d: '통제된 자습실과 생활 규정으로 집중 환경' },
];
---

<Layout title={`${academy} — 대입 재수종합 전문`}>
  <div class="p" style={`--accent:${accent}`}>
    <DemoBanner domain="prep.studiopeak.site" accent={accent} />

    <div class="p-notice">🎓 2027학년도 재수종합반 / 의대관 조기 마감 임박 — 지금 상담 예약하세요</div>

    <header class="p-head">
      <div class="wrap p-head-in">
        <span class="p-logo">{academy}</span>
        <nav><a href="#tracks">계열·관</a><a href="#manage">관리시스템</a><a href="#results">실적</a><a href="#contact">입학상담</a></nav>
        <a href="#contact" class="p-btn p-btn-sm">입학 상담</a>
      </div>
    </header>

    <section class="p-hero">
      <div class="wrap p-hero-in">
        <span class="p-tag">대입 재수·반수 종합 전문</span>
        <h1>다시 도전하는<br />당신의 <span>한 해</span>를 책임집니다</h1>
        <p>철저한 담임 관리, 매주 실전 모의고사, 입시 전문 컨설팅까지. 합격을 위한 모든 시스템이 한 곳에.</p>
        <div class="p-hero-cta">
          <a href="#contact" class="p-btn p-btn-lg">입학 상담 예약</a>
          <a href="#tracks" class="p-btn p-btn-out">계열 안내</a>
        </div>
      </div>
    </section>

    <section class="p-results" id="results">
      <div class="wrap p-results-in">
        <div><strong>1,240<em>명</em></strong><span>누적 합격생</span></div>
        <div><strong>92<em>%</em></strong><span>성적 향상률</span></div>
        <div><strong>38<em>명</em></strong><span>의·치·약 합격</span></div>
        <div><strong>15<em>년</em></strong><span>재수 전문</span></div>
      </div>
    </section>

    <section class="p-sec" id="tracks">
      <div class="wrap">
        <h2 class="p-h2">계열·관 안내</h2>
        <div class="p-tracks">
          {tracks.map((t) => (
            <article class="p-track">
              <span class="p-track-tag">{t.tag}</span>
              <h3>{t.t}</h3>
              <p>{t.d}</p>
              <a href="#contact" class="p-track-link">자세히 →</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="p-sec p-tint" id="manage">
      <div class="wrap">
        <h2 class="p-h2">합격을 만드는 관리 시스템</h2>
        <div class="p-manage">
          {manage.map((m, i) => (
            <div class="p-manage-item">
              <span class="p-manage-no">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3>{m.t}</h3>
                <p>{m.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="p-cta" id="contact">
      <div class="wrap p-cta-in">
        <div>
          <h2>합격, 올해 끝냅시다.</h2>
          <p>입학 상담 및 학원 투어를 예약하세요.</p>
        </div>
        <a href="tel:02-4567-8901" class="p-btn p-btn-lg">📞 02-4567-8901</a>
      </div>
    </section>

    <footer class="p-foot">
      <div class="wrap">
        <p>{academy} · 서울 강남구 테헤란로 123 본관 / 별관</p>
        <p class="p-by">© {year} {academy} — Website by <a href="https://studiopeak.site">PEAK STUDIO</a></p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .p { background: #0a0e16; color: #e2e8f0; font-family: 'Noto Sans KR', sans-serif; }
  .wrap { width: 100%; max-width: 1120px; margin-inline: auto; padding-inline: clamp(18px, 5vw, 40px); }
  .p a { text-decoration: none; }

  .p-notice { background: var(--accent); color: #fff; font-size: .84rem; font-weight: 600; text-align: center; padding: 9px 16px; }

  .p-head { position: sticky; top: 0; z-index: 20; background: rgba(10,14,22,.92); backdrop-filter: blur(8px); border-bottom: 1px solid #1e293b; }
  .p-head-in { display: flex; align-items: center; gap: 20px; height: 62px; }
  .p-logo { font-weight: 800; font-size: 1.2rem; color: #fff; }
  .p-head nav { display: flex; gap: 22px; margin-left: auto; }
  .p-head nav a { color: #94a3b8; font-size: .9rem; font-weight: 500; }
  .p-head nav a:hover { color: #fff; }

  .p-btn { display: inline-flex; align-items: center; justify-content: center; background: var(--accent); color: #fff; font-weight: 700; padding: 13px 26px; border-radius: 4px; transition: transform .2s, filter .2s; }
  .p-btn:hover { transform: translateY(-2px); filter: brightness(1.1); }
  .p-btn-sm { padding: 9px 16px; font-size: .9rem; }
  .p-btn-lg { padding: 16px 32px; font-size: 1.05rem; white-space: nowrap; }
  .p-btn-out { background: transparent; border: 1.5px solid #334155; color: #e2e8f0; }
  .p-btn-out:hover { border-color: var(--accent); }

  .p-hero { background: radial-gradient(110% 90% at 80% -20%, rgba(220,38,38,.28), transparent 55%), #0a0e16; padding-block: clamp(56px, 9vw, 110px); border-bottom: 1px solid #1e293b; }
  .p-tag { display: inline-block; border: 1px solid var(--accent); color: #fca5a5; font-weight: 700; font-size: .8rem; padding: 6px 14px; border-radius: 999px; }
  .p-hero h1 { font-size: clamp(2rem, 6vw, 3.6rem); font-weight: 800; line-height: 1.16; margin: 20px 0 16px; color: #fff; letter-spacing: -.02em; }
  .p-hero h1 span { color: var(--accent); }
  .p-hero p { max-width: 580px; color: #94a3b8; font-size: 1.05rem; }
  .p-hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }

  .p-results { background: #11161f; border-bottom: 1px solid #1e293b; }
  .p-results-in { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding-block: 36px; text-align: center; }
  .p-results strong { display: block; font-size: clamp(1.7rem, 4.5vw, 2.6rem); font-weight: 800; color: #fff; }
  .p-results strong em { font-style: normal; font-size: .55em; color: var(--accent); margin-left: 2px; }
  .p-results span { font-size: .85rem; color: #94a3b8; }

  .p-sec { padding-block: clamp(54px, 8vw, 92px); }
  .p-tint { background: #11161f; }
  .p-h2 { font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; text-align: center; color: #fff; margin-bottom: clamp(30px, 5vw, 50px); }

  .p-tracks { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 18px; }
  .p-track { background: #11161f; border: 1px solid #1e293b; border-top: 3px solid var(--accent); border-radius: 8px; padding: 26px 22px; transition: transform .2s, border-color .2s; }
  .p-track:hover { transform: translateY(-5px); border-color: var(--accent); }
  .p-track-tag { display: inline-block; background: rgba(220,38,38,.15); color: #fca5a5; font-size: .76rem; font-weight: 700; padding: 4px 10px; border-radius: 4px; }
  .p-track h3 { font-size: 1.3rem; color: #fff; margin: 12px 0 8px; }
  .p-track p { color: #94a3b8; font-size: .92rem; margin-bottom: 16px; }
  .p-track-link { color: var(--accent); font-weight: 700; font-size: .9rem; }

  .p-manage { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; }
  .p-manage-item { display: flex; gap: 16px; align-items: flex-start; background: #0a0e16; border: 1px solid #1e293b; border-radius: 8px; padding: 24px; }
  .p-manage-no { font-size: 1.6rem; font-weight: 800; color: var(--accent); line-height: 1; }
  .p-manage-item h3 { font-size: 1.12rem; color: #fff; margin-bottom: 6px; }
  .p-manage-item p { color: #94a3b8; font-size: .92rem; }

  .p-cta { background: var(--accent); color: #fff; padding-block: clamp(44px, 6vw, 72px); }
  .p-cta-in { display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between; }
  .p-cta h2 { font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; }
  .p-cta p { opacity: .92; margin-top: 6px; }
  .p-cta .p-btn-lg { background: #fff; color: var(--accent); }

  .p-foot { background: #060910; color: #64748b; padding-block: 26px; font-size: .85rem; }
  .p-foot p { margin: 2px 0; }
  .p-by a { color: #fca5a5; font-weight: 700; }

  @media (max-width: 760px) {
    .p-head nav { display: none; }
    .p-results-in { grid-template-columns: repeat(2, 1fr); gap: 26px 16px; }
    .p-cta-in { flex-direction: column; align-items: flex-start; }
  }
</style>
