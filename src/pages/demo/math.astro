---
import Layout from '../../layouts/Layout.astro';
import DemoBanner from '../../components/DemoBanner.astro';

const academy = '피크수학학원';
const accent = '#2563eb';
const year = new Date().getFullYear();

const steps = [
  { no: '01', t: '진단평가', d: '단원별 약점을 정밀 분석해 출발점을 찾습니다.' },
  { no: '02', t: '맞춤 커리큘럼', d: '학생별 학습 로드맵과 진도표를 설계합니다.' },
  { no: '03', t: '주 2회 클리닉', d: '틀린 문제는 그날 잡는 오답 관리 시스템.' },
  { no: '04', t: '주간 리포트', d: '학습량·점수를 매주 학부모님께 보고합니다.' },
];

const cases = [
  { name: '김O준 (고2)', before: '4등급', after: '1등급', period: '6개월' },
  { name: '이O서 (중3)', before: '78점', after: '97점', period: '3개월' },
  { name: '박O윤 (고1)', before: '5등급', after: '2등급', period: '5개월' },
  { name: '최O우 (고3)', before: '3등급', after: '1등급', period: '8개월' },
];
---

<Layout title={`${academy} — 성적으로 증명하는 수학`}>
  <div class="m" style={`--accent:${accent}`}>
    <DemoBanner domain="math.studiopeak.site" accent={accent} />

    <header class="m-head">
      <div class="wrap m-head-in">
        <span class="m-logo">{academy}</span>
        <nav><a href="#system">학습시스템</a><a href="#cases">성적사례</a><a href="#contact">상담</a></nav>
        <a href="#contact" class="m-btn m-btn-sm">레벨테스트 신청</a>
      </div>
    </header>

    <!-- HERO with graph -->
    <section class="m-hero">
      <div class="wrap m-hero-in">
        <div class="m-hero-txt">
          <span class="m-tag">소수정예 1:6 관리</span>
          <h1>점수로 증명하는<br />수학 학원</h1>
          <p>진단 → 맞춤 커리큘럼 → 오답 클리닉 → 주간 리포트.<br />데이터로 관리하는 피크수학의 검증된 시스템.</p>
          <div class="m-hero-cta">
            <a href="#contact" class="m-btn">무료 진단평가 신청</a>
            <a href="#system" class="m-btn m-btn-ghost">학습 시스템 보기</a>
          </div>
        </div>
        <div class="m-graph" aria-hidden="true">
          <div class="m-graph-title">평균 성적 향상 추이</div>
          <svg viewBox="0 0 280 180">
            <line x1="30" y1="150" x2="270" y2="150" stroke="#cbd5e1" />
            <line x1="30" y1="20" x2="30" y2="150" stroke="#cbd5e1" />
            {[
              { x: 55, h: 40 }, { x: 105, h: 70 }, { x: 155, h: 100 }, { x: 205, h: 130 },
            ].map((b) => (
              <rect x={b.x} y={150 - b.h} width="34" height={b.h} rx="4" fill="var(--accent)" opacity="0.88" />
            ))}
            <polyline points="72,110 122,80 172,50 222,20" fill="none" stroke="#0f172a" stroke-width="2.5" stroke-linecap="round" />
            {[110, 80, 50, 20].map((cy, i) => (
              <circle cx={72 + i * 50} cy={cy} r="4" fill="#0f172a" />
            ))}
          </svg>
          <div class="m-graph-x"><span>3월</span><span>6월</span><span>9월</span><span>12월</span></div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="m-stats">
      <div class="wrap m-stats-in">
        <div><strong>87%</strong><span>1등급 상승률</span></div>
        <div><strong>1:6</strong><span>소수정예 관리</span></div>
        <div><strong>142명</strong><span>최근 1년 1등급</span></div>
        <div><strong>12년</strong><span>누적 노하우</span></div>
      </div>
    </section>

    <!-- SYSTEM -->
    <section class="m-sec" id="system">
      <div class="wrap">
        <h2 class="m-h2">데이터로 관리하는 4단계 시스템</h2>
        <div class="m-steps">
          {steps.map((s) => (
            <div class="m-step">
              <span class="m-step-no">{s.no}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CASES TABLE -->
    <section class="m-sec m-tint" id="cases">
      <div class="wrap">
        <h2 class="m-h2">실제 성적 향상 사례</h2>
        <table class="m-table">
          <thead><tr><th>학생</th><th>이전</th><th>이후</th><th>기간</th></tr></thead>
          <tbody>
            {cases.map((c) => (
              <tr>
                <td class="m-name">{c.name}</td>
                <td class="m-before">{c.before}</td>
                <td class="m-after">{c.after} ↑</td>
                <td>{c.period}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="m-note">* 데모용 예시 데이터입니다.</p>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="m-cta" id="contact">
      <div class="wrap m-cta-in">
        <div>
          <h2>지금 무료 진단평가 받아보세요</h2>
          <p>약점 분석 리포트를 무료로 받아보실 수 있습니다.</p>
        </div>
        <a href="tel:02-1234-5678" class="m-btn m-btn-lg">📞 02-1234-5678</a>
      </div>
    </section>

    <footer class="m-foot">
      <div class="wrap">
        <p>{academy} · 서울 강남구 테헤란로 123, 4층</p>
        <p class="m-by">© {year} {academy} — Website by <a href="https://studiopeak.site">PEAK STUDIO</a></p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .m { background: #fff; color: #0f172a; font-family: 'Noto Sans KR', sans-serif; }
  .wrap { width: 100%; max-width: 1080px; margin-inline: auto; padding-inline: clamp(18px, 5vw, 40px); }
  .m a { text-decoration: none; }

  .m-head { position: sticky; top: 0; z-index: 20; background: rgba(255,255,255,.92); backdrop-filter: blur(8px); border-bottom: 1px solid #e8edf4; }
  .m-head-in { display: flex; align-items: center; gap: 20px; height: 60px; }
  .m-logo { font-weight: 800; font-size: 1.15rem; }
  .m-head nav { display: flex; gap: 22px; margin-left: auto; }
  .m-head nav a { color: #475569; font-size: .92rem; font-weight: 500; }
  .m-head nav a:hover { color: var(--accent); }

  .m-btn { display: inline-flex; align-items: center; justify-content: center; background: var(--accent); color: #fff; font-weight: 700; padding: 13px 24px; border-radius: 8px; transition: transform .2s, filter .2s; }
  .m-btn:hover { transform: translateY(-2px); filter: brightness(1.06); }
  .m-btn-sm { padding: 9px 16px; font-size: .9rem; }
  .m-btn-lg { padding: 16px 30px; font-size: 1.05rem; white-space: nowrap; }
  .m-btn-ghost { background: transparent; color: var(--accent); border: 1.5px solid var(--accent); }

  .m-hero { background: linear-gradient(180deg, #f8fafc, #eef3fb); padding-block: clamp(48px, 7vw, 88px); }
  .m-hero-in { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(28px, 5vw, 56px); align-items: center; }
  .m-tag { display: inline-block; background: #dbeafe; color: var(--accent); font-weight: 700; font-size: .82rem; padding: 6px 14px; border-radius: 6px; }
  .m-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.18; margin: 18px 0 14px; letter-spacing: -.02em; }
  .m-hero p { color: #475569; font-size: 1.05rem; }
  .m-hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }

  .m-graph { background: #fff; border: 1px solid #e3e9f2; border-radius: 16px; padding: 22px; box-shadow: 0 20px 50px rgba(15,23,42,.08); }
  .m-graph-title { font-weight: 700; font-size: .92rem; margin-bottom: 8px; }
  .m-graph svg { width: 100%; height: auto; }
  .m-graph-x { display: flex; justify-content: space-around; font-size: .78rem; color: #94a3b8; padding-left: 24px; }

  .m-stats { background: #0f172a; color: #fff; }
  .m-stats-in { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding-block: 34px; text-align: center; }
  .m-stats strong { display: block; font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; color: #93c5fd; }
  .m-stats span { font-size: .85rem; color: #cbd5e1; }

  .m-sec { padding-block: clamp(52px, 8vw, 90px); }
  .m-tint { background: #f6f9fd; }
  .m-h2 { font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; text-align: center; margin-bottom: clamp(30px, 5vw, 50px); letter-spacing: -.02em; }

  .m-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 18px; }
  .m-step { border: 1px solid #e3e9f2; border-left: 4px solid var(--accent); border-radius: 10px; padding: 24px 20px; background: #fff; }
  .m-step-no { font-size: 1.4rem; font-weight: 800; color: var(--accent); }
  .m-step h3 { font-size: 1.1rem; margin: 8px 0 6px; }
  .m-step p { color: #5a6675; font-size: .92rem; }

  .m-table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e3e9f2; border-radius: 12px; overflow: hidden; }
  .m-table th { background: #0f172a; color: #fff; padding: 14px; font-size: .9rem; text-align: center; }
  .m-table td { padding: 15px; border-top: 1px solid #eef2f7; text-align: center; color: #475569; }
  .m-name { font-weight: 700; color: #0f172a !important; }
  .m-before { color: #94a3b8 !important; text-decoration: line-through; }
  .m-after { color: var(--accent) !important; font-weight: 800; }
  .m-note { text-align: center; color: #94a3b8; font-size: .8rem; margin-top: 12px; }

  .m-cta { background: var(--accent); color: #fff; padding-block: clamp(40px, 6vw, 70px); }
  .m-cta-in { display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between; }
  .m-cta h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; }
  .m-cta p { opacity: .9; margin-top: 6px; }
  .m-cta .m-btn-lg { background: #fff; color: var(--accent); }

  .m-foot { background: #0b1120; color: #64748b; padding-block: 26px; font-size: .85rem; }
  .m-foot p { margin: 2px 0; }
  .m-by a { color: #93c5fd; font-weight: 700; }

  @media (max-width: 760px) {
    .m-hero-in { grid-template-columns: 1fr; }
    .m-head nav { display: none; }
    .m-stats-in { grid-template-columns: repeat(2, 1fr); gap: 24px 16px; }
    .m-cta-in { flex-direction: column; align-items: flex-start; }
  }
</style>
