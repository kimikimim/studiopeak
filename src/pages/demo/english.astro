---
import Layout from '../../layouts/Layout.astro';
import DemoBanner from '../../components/DemoBanner.astro';

const academy = '피크영어학원';
const accent = '#0ea5a4';
const year = new Date().getFullYear();

const levels = [
  { emoji: '🌱', t: '파닉스', d: '소리와 글자를 놀이로', age: '7세~초2' },
  { emoji: '💬', t: '회화 기초', d: '원어민과 첫 대화', age: '초3~초6' },
  { emoji: '📚', t: '내신 집중', d: '학교 시험 완벽 대비', age: '중1~중3' },
  { emoji: '🎯', t: '수능 독해', d: '유형별 실전 전략', age: '고1~고3' },
];

const teachers = [
  { initial: 'D', name: 'Daniel', role: '원어민 회화', desc: 'TESOL · 미국 명문대 졸 · 7년' },
  { initial: 'J', name: '정유진', role: '입시 영어', desc: '수능 영어 전문 10년 · 고려대' },
  { initial: 'A', name: 'Anna', role: '키즈 영어', desc: '유아·초등 전문 · 6년' },
];

const reviews = [
  { txt: '아이가 영어를 무서워했는데 이제 집에서도 영어로 말해요!', who: '초3 학부모' },
  { txt: '원어민 선생님 수업이 정말 재밌대요. 회화 실력이 확 늘었어요.', who: '중1 학부모' },
  { txt: '내신 1등급 받았어요. 유형별로 꼼꼼히 잡아주십니다.', who: '고2 학생' },
];
---

<Layout title={`${academy} — 읽고, 말하고, 시험까지`}>
  <div class="e" style={`--accent:${accent}`}>
    <DemoBanner domain="english.studiopeak.site" accent={accent} />

    <header class="e-head">
      <div class="wrap e-head-in">
        <span class="e-logo">🦊 {academy}</span>
        <a href="#contact" class="e-btn e-btn-sm">무료 체험수업</a>
      </div>
    </header>

    <section class="e-hero">
      <span class="e-blob e-blob1"></span>
      <span class="e-blob e-blob2"></span>
      <div class="wrap e-hero-in">
        <span class="e-pill">원어민 회화 + 입시 영어</span>
        <h1>읽고, 말하고,<br /><em>시험까지!</em></h1>
        <p>영어가 즐거워지는 학원. 원어민 회화로 자신감을, 체계적인 커리큘럼으로 성적을 잡아드려요.</p>
        <a href="#contact" class="e-btn e-btn-lg">무료 레벨테스트 받기 →</a>
        <div class="e-hero-stats">
          <span>👩‍🏫 원어민 4명</span><span>😊 재등록률 92%</span><span>⏱️ 9년 운영</span>
        </div>
      </div>
    </section>

    <section class="e-sec" id="levels">
      <div class="wrap">
        <h2 class="e-h2">우리 아이 딱 맞는 단계로</h2>
        <div class="e-levels">
          {levels.map((l) => (
            <div class="e-level">
              <span class="e-emoji">{l.emoji}</span>
              <h3>{l.t}</h3>
              <p>{l.d}</p>
              <span class="e-age">{l.age}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="e-sec e-tint" id="teachers">
      <div class="wrap">
        <h2 class="e-h2">친근한 선생님들 🧡</h2>
        <div class="e-teachers">
          {teachers.map((t) => (
            <div class="e-teacher">
              <span class="e-avatar">{t.initial}</span>
              <h3>{t.name}</h3>
              <span class="e-role">{t.role}</span>
              <p>{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="e-sec" id="reviews">
      <div class="wrap">
        <h2 class="e-h2">학부모·학생 후기</h2>
        <div class="e-reviews">
          {reviews.map((r) => (
            <div class="e-review">
              <p>“{r.txt}”</p>
              <span>— {r.who}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="e-cta" id="contact">
      <div class="wrap e-cta-in">
        <h2>첫 수업은 무료예요! 😊</h2>
        <p>부담 없이 체험해보고 결정하세요.</p>
        <a href="tel:02-2345-6789" class="e-btn e-btn-lg e-btn-white">📞 02-2345-6789</a>
      </div>
    </section>

    <footer class="e-foot">
      <div class="wrap">
        <p>{academy} · 서울 강남구 테헤란로 123, 5층</p>
        <p class="e-by">© {year} {academy} — Website by <a href="https://studiopeak.site">PEAK STUDIO</a></p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .e { background: #fff; color: #134e4a; font-family: 'Noto Sans KR', sans-serif; }
  .wrap { width: 100%; max-width: 1060px; margin-inline: auto; padding-inline: clamp(18px, 5vw, 40px); }
  .e a { text-decoration: none; }

  .e-head { position: sticky; top: 0; z-index: 20; background: rgba(255,255,255,.9); backdrop-filter: blur(8px); }
  .e-head-in { display: flex; align-items: center; height: 62px; }
  .e-logo { font-weight: 800; font-size: 1.15rem; color: #0f766e; }
  .e-head .e-btn { margin-left: auto; }

  .e-btn { display: inline-flex; align-items: center; justify-content: center; background: var(--accent); color: #fff; font-weight: 700; padding: 14px 26px; border-radius: 999px; transition: transform .2s, box-shadow .2s; box-shadow: 0 8px 22px rgba(14,165,164,.3); }
  .e-btn:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(14,165,164,.4); }
  .e-btn-sm { padding: 9px 18px; font-size: .9rem; }
  .e-btn-lg { padding: 16px 32px; font-size: 1.05rem; }
  .e-btn-white { background: #fff; color: var(--accent); }

  .e-hero { position: relative; overflow: hidden; background: linear-gradient(160deg, #ecfeff 0%, #f0fdfa 100%); padding-block: clamp(54px, 9vw, 100px); text-align: center; }
  .e-blob { position: absolute; border-radius: 50%; filter: blur(8px); opacity: .5; }
  .e-blob1 { width: 200px; height: 200px; background: #99f6e4; top: -40px; left: -40px; }
  .e-blob2 { width: 260px; height: 260px; background: #a5f3fc; bottom: -80px; right: -60px; }
  .e-hero-in { position: relative; display: flex; flex-direction: column; align-items: center; }
  .e-pill { background: #fff; color: var(--accent); font-weight: 700; font-size: .85rem; padding: 8px 18px; border-radius: 999px; box-shadow: 0 4px 14px rgba(14,165,164,.15); }
  .e-hero h1 { font-size: clamp(2.2rem, 7vw, 4rem); font-weight: 800; line-height: 1.1; margin: 22px 0 16px; color: #0f766e; }
  .e-hero h1 em { font-style: normal; color: #f59e0b; }
  .e-hero p { max-width: 520px; color: #14746e; font-size: 1.08rem; margin-bottom: 28px; }
  .e-hero-stats { display: flex; flex-wrap: wrap; gap: 14px 26px; justify-content: center; margin-top: 30px; font-weight: 600; color: #0f766e; font-size: .95rem; }

  .e-sec { padding-block: clamp(50px, 8vw, 88px); }
  .e-tint { background: #f0fdfa; }
  .e-h2 { font-size: clamp(1.5rem, 4vw, 2.3rem); font-weight: 800; text-align: center; color: #0f766e; margin-bottom: clamp(30px, 5vw, 50px); }

  .e-levels { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
  .e-level { background: #fff; border: 2px solid #ccfbf1; border-radius: 24px; padding: 30px 22px; text-align: center; transition: transform .25s, border-color .25s; }
  .e-level:hover { transform: translateY(-6px); border-color: var(--accent); }
  .e-emoji { font-size: 2.4rem; }
  .e-level h3 { font-size: 1.2rem; color: #0f766e; margin: 12px 0 6px; }
  .e-level p { color: #5a8a86; font-size: .92rem; }
  .e-age { display: inline-block; margin-top: 12px; background: #ccfbf1; color: var(--accent); font-weight: 700; font-size: .8rem; padding: 4px 12px; border-radius: 999px; }

  .e-teachers { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }
  .e-teacher { background: #fff; border-radius: 24px; padding: 30px 24px; text-align: center; box-shadow: 0 10px 30px rgba(14,165,164,.08); }
  .e-avatar { display: inline-flex; align-items: center; justify-content: center; width: 70px; height: 70px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), #22d3ee); color: #fff; font-size: 1.8rem; font-weight: 800; }
  .e-teacher h3 { font-size: 1.2rem; color: #0f766e; margin-top: 14px; }
  .e-role { display: block; color: var(--accent); font-weight: 700; font-size: .88rem; margin: 4px 0 8px; }
  .e-teacher p { color: #5a8a86; font-size: .9rem; }

  .e-reviews { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
  .e-review { background: #fff; border: 2px dashed #99f6e4; border-radius: 20px; padding: 26px; }
  .e-review p { color: #134e4a; font-size: 1rem; line-height: 1.6; }
  .e-review span { display: block; margin-top: 14px; color: var(--accent); font-weight: 700; font-size: .88rem; }

  .e-cta { background: linear-gradient(135deg, var(--accent), #06b6d4); color: #fff; padding-block: clamp(50px, 7vw, 80px); text-align: center; }
  .e-cta h2 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; }
  .e-cta p { opacity: .92; margin: 10px 0 26px; }

  .e-foot { background: #134e4a; color: #99f6e4; padding-block: 26px; font-size: .85rem; }
  .e-foot p { margin: 2px 0; }
  .e-by a { color: #fff; font-weight: 700; }

  @media (max-width: 600px) {
    .e-hero-stats { flex-direction: column; gap: 8px; }
  }
</style>
