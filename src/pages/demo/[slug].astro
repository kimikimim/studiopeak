---
import Layout from '../../layouts/Layout.astro';
import { demos } from '../../data/demos';

export function getStaticPaths() {
  return demos.map((demo) => ({
    params: { slug: demo.slug },
    props: { demo },
  }));
}

const { demo } = Astro.props;
const year = new Date().getFullYear();
---

<Layout title={`${demo.academyName} — ${demo.subject} 전문 학원`}>
  <div class="demo" style={`--demo-accent:${demo.theme.accent};--demo-accent-soft:${demo.theme.accentSoft}`}>
    <!-- 데모 안내 배너 -->
    <div class="demo-banner">
      <span>📐 이 페이지는 <strong>PEAK STUDIO</strong> 데모입니다 · <strong>{demo.futureDomain}</strong></span>
      <a href="https://studiopeak.site/#contact">우리 학원도 만들기 →</a>
    </div>

    <!-- HEADER -->
    <header class="demo-header">
      <div class="container demo-header-inner">
        <a href={`/demo/${demo.slug}`} class="demo-logo">{demo.academyName}</a>
        <nav class="demo-nav">
          <a href="#features">특장점</a>
          <a href="#programs">프로그램</a>
          <a href="#teachers">강사진</a>
          <a href="#schedule">시간표</a>
        </nav>
        <a href="#contact" class="demo-btn demo-btn-sm">상담 신청</a>
      </div>
    </header>

    <!-- HERO -->
    <section class="demo-hero">
      <div class="container demo-hero-inner">
        <span class="demo-badge">{demo.hero.badge}</span>
        <h1>{demo.hero.title}</h1>
        <p>{demo.hero.subtitle}</p>
        <div class="demo-hero-cta">
          <a href="#contact" class="demo-btn">무료 레벨테스트 신청</a>
          <a href="#programs" class="demo-btn demo-btn-ghost">프로그램 보기</a>
        </div>
        <dl class="demo-stats">
          {demo.stats.map((s) => (
            <div>
              <dt>{s.value}</dt>
              <dd>{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="demo-section" id="features">
      <div class="container">
        <h2 class="demo-h2">왜 {demo.academyName}일까요?</h2>
        <div class="demo-grid demo-grid-3">
          {demo.features.map((f, i) => (
            <article class="demo-card">
              <span class="demo-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PROGRAMS -->
    <section class="demo-section demo-tint" id="programs">
      <div class="container">
        <h2 class="demo-h2">학년별 프로그램</h2>
        <div class="demo-grid demo-grid-3">
          {demo.programs.map((p) => (
            <article class="demo-program">
              <span class="demo-tag">{p.target}</span>
              <h3>{p.name}</h3>
              <p>{p.desc}</p>
              <span class="demo-time">🕒 {p.time}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section class="demo-results">
      <div class="container demo-results-inner">
        <h2 class="demo-h2 demo-h2-light">숫자로 증명하는 결과</h2>
        <div class="demo-grid demo-grid-3">
          {demo.results.map((r) => (
            <div class="demo-result">
              <strong>{r.value}</strong>
              <span>{r.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TEACHERS -->
    <section class="demo-section" id="teachers">
      <div class="container">
        <h2 class="demo-h2">검증된 강사진</h2>
        <div class="demo-grid demo-grid-2">
          {demo.teachers.map((t) => (
            <article class="demo-teacher">
              <div class="demo-avatar">{t.name.charAt(0)}</div>
              <div>
                <h3>{t.name}</h3>
                <span class="demo-role">{t.role}</span>
                <p>{t.career}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SCHEDULE -->
    <section class="demo-section demo-tint" id="schedule">
      <div class="container">
        <h2 class="demo-h2">주간 시간표</h2>
        <table class="demo-table">
          <thead>
            <tr><th>요일</th><th>운영 클래스</th></tr>
          </thead>
          <tbody>
            {demo.schedule.map((row) => (
              <tr>
                <td class="demo-day">{row.day}</td>
                <td>{row.classes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="demo-contact" id="contact">
      <div class="container demo-contact-inner">
        <div>
          <h2 class="demo-h2 demo-h2-light">지금, 무료 상담받아 보세요</h2>
          <ul class="demo-contact-meta">
            <li><strong>전화</strong> {demo.contact.phone}</li>
            <li><strong>위치</strong> {demo.contact.address}</li>
            <li><strong>운영</strong> {demo.contact.hours}</li>
          </ul>
        </div>
        <a href={`tel:${demo.contact.phone}`} class="demo-btn demo-btn-lg">📞 전화 상담하기</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="demo-footer">
      <div class="container">
        <p>{demo.academyName} · {demo.contact.address}</p>
        <p class="demo-footer-by">
          © {year} {demo.academyName} — Website by
          <a href="https://studiopeak.site">PEAK STUDIO</a>
        </p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .demo {
    background: #f8fafc;
    color: #1f2937;
  }

  .container {
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 40px);
  }

  /* 데모 안내 배너 */
  .demo-banner {
    background: #0f172a;
    color: #cbd5e1;
    font-size: 0.82rem;
    padding: 9px clamp(16px, 4vw, 32px);
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .demo-banner strong { color: #fff; }
  .demo-banner a { color: var(--demo-accent); font-weight: 700; white-space: nowrap; }

  /* HEADER */
  .demo-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #e7ecf3;
  }
  .demo-header-inner { display: flex; align-items: center; gap: 20px; height: 62px; }
  .demo-logo { font-weight: 800; font-size: 1.15rem; color: #0f172a; letter-spacing: -0.02em; }
  .demo-nav { display: flex; gap: 24px; margin-left: auto; }
  .demo-nav a { color: #475569; font-size: 0.92rem; font-weight: 500; transition: color 0.2s; }
  .demo-nav a:hover { color: var(--demo-accent); }

  /* BUTTONS */
  .demo-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--demo-accent); color: #fff; font-weight: 700;
    padding: 13px 26px; border-radius: 999px; transition: transform 0.2s, filter 0.2s;
    white-space: nowrap;
  }
  .demo-btn:hover { transform: translateY(-2px); filter: brightness(1.05); }
  .demo-btn-sm { padding: 9px 18px; font-size: 0.9rem; }
  .demo-btn-lg { padding: 16px 34px; font-size: 1.05rem; }
  .demo-btn-ghost { background: transparent; color: var(--demo-accent); border: 1px solid var(--demo-accent); }
  .demo-btn-ghost:hover { background: var(--demo-accent-soft); }

  /* HERO */
  .demo-hero {
    background:
      radial-gradient(90% 90% at 80% -10%, var(--demo-accent-soft) 0%, transparent 55%),
      linear-gradient(180deg, #fff 0%, #f1f5f9 100%);
    padding-block: clamp(60px, 9vw, 110px);
    text-align: center;
  }
  .demo-hero-inner { display: flex; flex-direction: column; align-items: center; }
  .demo-badge {
    background: var(--demo-accent-soft); color: var(--demo-accent);
    font-weight: 700; font-size: 0.84rem; padding: 7px 16px; border-radius: 999px;
  }
  .demo-hero h1 {
    font-size: clamp(2rem, 6vw, 3.6rem); font-weight: 800; letter-spacing: -0.03em;
    color: #0f172a; margin: 20px 0 16px; line-height: 1.15;
  }
  .demo-hero p { max-width: 560px; color: #475569; font-size: clamp(1rem, 2.2vw, 1.15rem); }
  .demo-hero-cta { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 30px; }
  .demo-stats {
    display: flex; flex-wrap: wrap; justify-content: center; gap: clamp(28px, 6vw, 60px);
    margin-top: 48px; padding-top: 32px; border-top: 1px solid #e2e8f0; width: 100%; max-width: 560px;
  }
  .demo-stats dt { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; color: var(--demo-accent); }
  .demo-stats dd { font-size: 0.85rem; color: #64748b; margin-top: 4px; }

  /* SECTIONS */
  .demo-section { padding-block: clamp(56px, 8vw, 96px); }
  .demo-tint { background: #fff; }
  .demo-h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; letter-spacing: -0.02em;
    color: #0f172a; text-align: center; margin-bottom: clamp(32px, 5vw, 52px);
  }
  .demo-h2-light { color: #fff; }

  .demo-grid { display: grid; gap: 20px; }
  .demo-grid-2 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .demo-grid-3 { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }

  /* FEATURE CARD */
  .demo-card {
    background: #fff; border: 1px solid #e7ecf3; border-radius: 16px; padding: 28px 24px;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .demo-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08); }
  .demo-num { font-size: 1.6rem; font-weight: 800; color: var(--demo-accent); }
  .demo-card h3 { font-size: 1.15rem; color: #0f172a; margin: 10px 0 8px; }
  .demo-card p { color: #5a6675; font-size: 0.95rem; }

  /* PROGRAM */
  .demo-program {
    background: #fff; border: 1px solid #e7ecf3; border-top: 4px solid var(--demo-accent);
    border-radius: 14px; padding: 26px 22px;
  }
  .demo-tag {
    display: inline-block; background: var(--demo-accent-soft); color: var(--demo-accent);
    font-size: 0.78rem; font-weight: 700; padding: 4px 11px; border-radius: 999px; margin-bottom: 12px;
  }
  .demo-program h3 { font-size: 1.2rem; color: #0f172a; margin-bottom: 8px; }
  .demo-program p { color: #5a6675; font-size: 0.93rem; margin-bottom: 16px; }
  .demo-time { font-size: 0.85rem; color: #64748b; font-weight: 600; }

  /* RESULTS */
  .demo-results {
    background: linear-gradient(135deg, var(--demo-accent), color-mix(in srgb, var(--demo-accent) 60%, #0f172a));
    padding-block: clamp(48px, 7vw, 80px); color: #fff;
  }
  .demo-result { text-align: center; }
  .demo-result strong { display: block; font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 800; }
  .demo-result span { color: rgba(255, 255, 255, 0.85); font-size: 0.92rem; }

  /* TEACHERS */
  .demo-teacher {
    display: flex; gap: 18px; align-items: flex-start;
    background: #fff; border: 1px solid #e7ecf3; border-radius: 16px; padding: 24px;
  }
  .demo-avatar {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 50%;
    background: var(--demo-accent); color: #fff; font-weight: 800; font-size: 1.4rem;
    display: flex; align-items: center; justify-content: center;
  }
  .demo-teacher h3 { font-size: 1.1rem; color: #0f172a; }
  .demo-role { display: block; color: var(--demo-accent); font-weight: 700; font-size: 0.88rem; margin: 2px 0 8px; }
  .demo-teacher p { color: #5a6675; font-size: 0.9rem; }

  /* SCHEDULE TABLE */
  .demo-table {
    width: 100%; border-collapse: collapse; background: #fff;
    border: 1px solid #e7ecf3; border-radius: 14px; overflow: hidden;
  }
  .demo-table th {
    background: #0f172a; color: #fff; text-align: left; padding: 14px 20px; font-size: 0.92rem;
  }
  .demo-table td { padding: 16px 20px; border-top: 1px solid #eef2f7; color: #475569; font-size: 0.95rem; }
  .demo-day { font-weight: 700; color: var(--demo-accent); white-space: nowrap; }

  /* CONTACT */
  .demo-contact {
    background: #0f172a; color: #cbd5e1; padding-block: clamp(48px, 7vw, 80px);
  }
  .demo-contact-inner {
    display: flex; flex-wrap: wrap; gap: 28px; align-items: center; justify-content: space-between;
  }
  .demo-contact .demo-h2 { text-align: left; margin-bottom: 22px; }
  .demo-contact-meta { list-style: none; display: grid; gap: 10px; }
  .demo-contact-meta li { font-size: 0.96rem; }
  .demo-contact-meta strong { display: inline-block; width: 52px; color: #64748b; font-weight: 600; }

  /* FOOTER */
  .demo-footer { background: #0b1120; color: #64748b; padding-block: 28px; font-size: 0.85rem; }
  .demo-footer p { margin: 2px 0; }
  .demo-footer-by a { color: var(--demo-accent); font-weight: 700; }

  @media (max-width: 760px) {
    .demo-nav { display: none; }
    .demo-contact-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
