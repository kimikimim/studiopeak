  }

  .portfolio-card.disabled {
    cursor: default;
    opacity: 0.78;
  }

  .portfolio-card.disabled:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  .portfolio-thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    background: linear-gradient(150deg, var(--card-accent), color-mix(in srgb, var(--card-accent) 55%, #0b1f3a));
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .portfolio-peak {
    width: 100%;
    height: auto;
  }

  .portfolio-tag {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(0, 0, 0, 0.18);
    padding: 5px 11px;
    border-radius: 999px;
  }

  .portfolio-soon {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--color-ink);
    background: rgba(255, 255, 255, 0.9);
    padding: 5px 11px;
    border-radius: 999px;
  }

  .portfolio-body {
    padding: 22px 22px 24px;
  }

  .portfolio-body h3 {
    font-size: 1.2rem;
    color: var(--color-ink);
    margin-bottom: 8px;
  }

  .portfolio-body p {
    color: var(--color-text-ink-dim);
    font-size: 0.92rem;
    margin-bottom: 16px;
  }

  .portfolio-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-navy-500);
  }

  .portfolio-link svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s var(--ease);
  }

  .portfolio-card:not(.disabled):hover .portfolio-link svg {
    transform: translateX(4px);
  }

  /* ─────────── PROCESS ─────────── */
  .process-track {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    counter-reset: step;
  }

  .process-step {
    position: relative;
    padding: 28px 24px;
    border-radius: var(--radius-md);
    background: var(--color-white);
    border: 1px solid var(--color-cloud);
    box-shadow: var(--shadow-sm);
  }

  .process-step::after {
    content: '';
    position: absolute;
    top: 50%;
    right: -16px;
    width: 16px;
    height: 2px;
    background: var(--color-silver);
  }

  .process-step:last-child::after {
    display: none;
  }

  .process-no {
    font-family: 'Inter', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
    background: var(--accent);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .process-content h3 {
    font-size: 1.15rem;
    color: var(--color-ink);
    margin: 14px 0 8px;
  }

  .process-content p {
    color: var(--color-text-ink-dim);
    font-size: 0.94rem;
  }

  /* ─────────── CONTACT ─────────── */
  .contact {
    background: linear-gradient(160deg, var(--color-charcoal) 0%, var(--color-navy) 100%);
    color: var(--color-text);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(36px, 6vw, 72px);
    align-items: center;
  }

  .eyebrow-light {
    color: #93c5fd;
  }

  .contact-info h2 {
    font-size: clamp(1.6rem, 3.6vw, 2.4rem);
    color: var(--color-white);
    margin: 14px 0 14px;
  }

  .contact-info > p {
    color: var(--color-text-dim);
    margin-bottom: 28px;
  }

  .contact-meta {
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .contact-meta li {
    font-size: 0.95rem;
    color: var(--color-silver);
  }

  .contact-meta strong {
    display: inline-block;
    width: 64px;
    color: var(--color-text-dim);
    font-weight: 600;
  }

  .contact-form {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(199, 206, 217, 0.16);
    border-radius: var(--radius-lg);
    padding: clamp(24px, 4vw, 36px);
    box-shadow: var(--shadow-lg);
  }

  .field-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field span {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-silver);
  }

  .field i {
    color: #93c5fd;
    font-style: normal;
    margin-left: 2px;
  }

  .field input,
  .field textarea {
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--color-white);
    background: rgba(11, 31, 58, 0.5);
    border: 1px solid rgba(199, 206, 217, 0.22);
    border-radius: var(--radius-sm);
    padding: 13px 14px;
    transition:
      border-color 0.2s var(--ease),
      box-shadow 0.2s var(--ease);
    resize: vertical;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-silver-soft);
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.25);
  }

  .form-submit {
    width: 100%;
    margin-top: 20px;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .form-result {
    margin-top: 16px;
    text-align: center;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .form-result.is-ok {
    color: #6ee7b7;
  }

  .form-result.is-error {
    color: #fca5a5;
  }

  /* ─────────── FOOTER ─────────── */
  .footer {
    background: var(--color-charcoal);
    color: var(--color-text-dim);
    padding-block: 44px;
    border-top: 1px solid rgba(199, 206, 217, 0.1);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px 40px;
  }

  .footer-brand p {
    font-size: 0.88rem;
    margin-top: 8px;
  }

  .logo-text-light {
    font-size: 1.1rem;
  }

  .footer-nav {
    display: flex;
    gap: 22px;
    margin-left: auto;
  }

  .footer-nav a {
    font-size: 0.9rem;
    transition: color 0.2s var(--ease);
  }

  .footer-nav a:hover {
    color: var(--color-white);
  }

  .footer-copy {
    width: 100%;
    font-size: 0.82rem;
    color: var(--color-silver-soft);
    padding-top: 18px;
    border-top: 1px solid rgba(199, 206, 217, 0.08);
  }

  /* ─────────── RESPONSIVE ─────────── */
  @media (max-width: 860px) {
    .nav {
      display: none;
    }

    .contact-inner {
      grid-template-columns: 1fr;
    }

    .process-step::after {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .header-cta {
      margin-left: auto;
    }

    .hero-actions .btn {
      flex: 1 1 100%;
    }
  }
</style>

<script>
  // 스크롤 진입 시 카드 페이드인 (선택적 향상)
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          (e.target as HTMLElement).style.opacity = '1';
          (e.target as HTMLElement).style.transform = 'none';
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.12 },
  );

  document
    .querySelectorAll('.value-card, .portfolio-card, .process-step')
    .forEach((el) => {
      const node = el as HTMLElement;
      node.style.opacity = '0';
      node.style.transform = 'translateY(18px)';
      node.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      io.observe(node);
    });

  // ─────────── 견적 문의 폼 (Web3Forms) ───────────
  const form = document.getElementById('estimate-form') as HTMLFormElement | null;
  const result = document.getElementById('form-result') as HTMLElement | null;

  if (form && result) {
    const key = form.dataset.web3formsKey?.trim();
    const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
    const defaultLabel = submitBtn?.textContent ?? '';

    const show = (msg: string, ok: boolean) => {
      result.textContent = msg;
      result.classList.toggle('is-ok', ok);
      result.classList.toggle('is-error', !ok);
      result.hidden = false;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // 액세스 키 미설정 시: 실수로 빈 제출이 새지 않도록 안내
      if (!key) {
        show('⚠ 폼이 아직 연결되지 않았습니다. 이메일로 직접 문의해 주세요.', false);
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = '전송 중...';
      }

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();

        if (data.success) {
          show('✓ 문의가 접수되었습니다. 빠르게 연락드리겠습니다!', true);
          form.reset();
        } else {
          show('전송에 실패했습니다. 잠시 후 다시 시도하거나 이메일로 문의해 주세요.', false);
        }
      } catch {
        show('네트워크 오류로 전송하지 못했습니다. 이메일로 문의해 주세요.', false);
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = defaultLabel;
        }
      }
    });
  }
</script>
